{
  "manifest_version": 3,
  "name": "arXiv Paper Downloader",
  "description": "Download arXiv papers with customizable filenames. Default: FirstAuthor-Year-Title",
  "version": "1.1.0",
  "permissions": ["downloads", "storage", "activeTab"],
  "host_permissions": ["https://arxiv.org/*", "https://export.arxiv.org/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://arxiv.org/abs/*"],
      "js": ["utils.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "arXiv Paper Downloader"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
